# AI Provider API Keys
# Choose one or more providers - the app will use the first available key

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# BLACKBOX AI API Configuration
BLACKBOX_API_KEY=your_blackbox_api_key_here

# Default AI Provider (openai, gemini, claude, or blackbox)
DEFAULT_AI_PROVIDER=openai

# Instructions:
# 1. Rename this file to .env
# 2. Add at least one API key above
# 3. Set your preferred DEFAULT_AI_PROVIDER
# 4. Save the file

# Get API Keys:
# - OpenAI: https://platform.openai.com/api-keys
# - Gemini: https://makersuite.google.com/app/apikey
# - Claude: https://console.anthropic.com/
# - BLACKBOX: https://www.blackbox.ai/
