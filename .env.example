# ──────────────────────────────────────────────────────────────────────────
#  AutoMoto AI  —  environment configuration
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────

# ── AI Provider API keys (add at least one) ──────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
BLACKBOX_API_KEY=

# ── Default provider: openai | gemini | claude | blackbox ────────────────
DEFAULT_AI_PROVIDER=openai

# ── Optional: override default models ────────────────────────────────────
# OPENAI_MODEL=gpt-4
# GEMINI_MODEL=gemini-pro
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
# BLACKBOX_MODEL=blackboxai

# ── AI generation parameters ─────────────────────────────────────────────
# AI_TEMPERATURE=0.3
# AI_MAX_TOKENS=1024

# ── Web server ────────────────────────────────────────────────────────────
# WEB_HOST=127.0.0.1
# WEB_PORT=5000
# FLASK_DEBUG=false
# FLASK_SECRET_KEY=change-me-in-production

# ── Logging ───────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
